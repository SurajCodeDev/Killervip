    </div>

    <!-- MAIN CONTAINER -->
    <div class="killer-container">
        <!-- HEADER -->
        <div class="killer-header">
            <h1>🔪 KILLER VIP</h1>
            <span class="header-badge"><i class="fas fa-crown"></i> PREMIUM KEYS</span>
