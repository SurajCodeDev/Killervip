            <!-- BRAND SELECT -->
            <div class="form-group">
                <label><i class="fas fa-server"></i> SELECT BRAND</label>
                <select id="brandSelect" onchange="handleBrandChange()">
                    <option value="">-- CHOOSE SERVER --</option>
                    <option value="brutal">💀 BRUTAL SERVER</option>
                    <option value="bgmi">⚡ BGMI LOADER</option>
                </select>
            </div>

            <!-- PRICE PLANS (YOUR EXACT RATES) -->
            <div class="plans-grid" id="plansContainer">
                <!-- Filled by JS -->
            </div>

            <!-- SELECTED PLAN DISPLAY -->
            <div id="selectedPlanDisplay" style="color:#ffaa33; font-size:1.1rem; text-align:center; margin:10px 0;"></div>

            <!-- UPI SECTION -->
            <div class="upi-section">
                <div class="upi-id-box">
                    <h3><i class="fas fa-qrcode"></i> UPI PAYMENT</h3>
                    <div class="upi-id">ksuraj138@ybl</div>
                </div>
                
                <div style="text-align:center;">
                    <div id="qrcode"></div>
                    <button class="btn-qr" onclick="downloadQR()">
                        <i class="fas fa-download"></i> DOWNLOAD QR
                    </button>
                </div>
            </div>

            <!-- PAYMENT PROOF BUTTONS -->
            <div class="proof-buttons">
                <a href="https://wa.me/919876543210?text=Hello%20KILLER%20VIP%2C%20I%27ve%20made%20payment%20of%20Rs%20[AMOUNT]%20for%20[PLAN]%20key.%20Please%20verify." target="_blank" class="btn-proof btn-wa">
                    <i class="fab fa-whatsapp"></i> WHATSAPP
                </a>
                <a href="https://t.me/killervip_support" target="_blank" class="btn-proof btn-tg">
                    <i class="fab fa-telegram"></i> TELEGRAM
                </a>
            </div>

            <!-- PURCHASE BUTTON -->
            <button class="purchase-btn" onclick="purchaseKey()">
                <i class="fas fa-bolt"></i> BUY NOW
            </button>
        </div>

        <!-- FOOTER -->
        <div class="footer-links">
            <a href="#" onclick="showModal('privacy')">Privacy Policy</a>
            <a href="#" onclick="showModal('refund')">Refund Policy</a>
            <a href="#" onclick="showModal('terms')">Terms</a>
            <a href="#" onclick="showModal('support')">Contact</a>
        </div>
        <div style="text-align:center; color:#444; font-size:0.8rem;">© 2025 KILLER VIP 🔥</div>
    </div>

    <!-- MODAL FOR PAGES -->
    <div id="modal" class="modal" onclick="if(event.target === this) hideModal()">
        <div class="modal-content">
            <h2 id="modalTitle"></h2>
            <div id="modalBody"></div>
            <button class="close-modal" onclick="hideModal()">CLOSE</button>
        </div>
    </div>

    <script>
        // ========== KILLER VIP FUNCTIONS ==========
        const plansData = [
            { name: '5 HOURS', price: 30, icon: 'fa-hourglass-half', duration: '5h' },
            { name: '1 DAY', price: 90, icon: 'fa-sun', duration: '1d' },
            { name: '3 DAYS', price: 200, icon: 'fa-calendar-day', duration: '3d' },
            { name: '7 DAYS', price: 450, icon: 'fa-calendar-week', duration: '7d' },
            { name: '15 DAYS', price: 800, icon: 'fa-calendar-alt', duration: '15d' },
            { name: '30 DAYS', price: 999, icon: 'fa-calendar-check', duration: '30d' },
            { name: '60 DAYS', price: 1500, icon: 'fa-calendar-plus', duration: '60d' }
        ];

        let selectedBrand = '';
        let selectedPlan = null;
        let currentPrice = 0;

        // Initialize
        window.onload = function() {
            renderPlans();
            generateQR();
        };

        function renderPlans() {
            const container = document.getElementById('plansContainer');
            container.innerHTML = '';
            plansData.forEach((plan, index) => {
                const card = document.createElement('div');
                card.className = 'plan-card' + (selectedPlan === index ? ' selected' : '');
                card.onclick = () => selectPlan(index);
                card.innerHTML = `
                    <div class="plan-icon"><i class="fas ${plan.icon}"></i></div>
                    <div class="plan-name">${plan.name}</div>
                    <div class="plan-price">₹${plan.price}</div>
                `;
                container.appendChild(card);
            });
        }

        function selectPlan(index) {
            selectedPlan = index;
            currentPrice = plansData[index].price;
            document.getElementById('selectedPlanDisplay').innerHTML = `✅ SELECTED: ${plansData[index].name} - ₹${plansData[index].price}`;
            renderPlans(); // Re-render to highlight selected
            generateQR(); // Update QR with amount
        }

        function handleBrandChange() {
            selectedBrand = document.getElementById('brandSelect').value;
            if (!selectedBrand) {
                selectedPlan = null;
                currentPrice = 0;
                document.getElementById('selectedPlanDisplay').innerHTML = '';
                renderPlans();
                generateQR();
            }
        }

        function generateQR() {
            const upiId = "ksuraj138@ybl";
            const amount = currentPrice || 1;
            const upiString = `upi://pay?pa=${upiId}&pn=KILLER%20VIP&am=${amount}&cu=INR`;
            
            document.getElementById('qrcode').innerHTML = '';
            
            QRCode.toCanvas(document.createElement('canvas'), upiString, {
                width: 200,
                margin: 2,
                color: { dark: '#000000', light: '#ffffff' }
            }, function(error, canvas) {
                if (error) {
                    console.error(error);
                    return;
                }
                document.getElementById('qrcode').appendChild(canvas);
            });
        }

        function downloadQR() {
            const canvas = document.querySelector('#qrcode canvas');
            if (!canvas) {
                alert('QR not ready!');
                return;
            }
            const link = document.createElement('a');
            link.download = `KILLER_VIP_₹${currentPrice}.png`;
            link.href = canvas.toDataURL('image/png');
            link.click();
        }

        function purchaseKey() {
            if (!selectedBrand) {
                alert('❌ Pehle brand select karo!');
                return;
            }
            if (selectedPlan === null) {
                alert('❌ Pehle plan select karo!');
                return;
            }
            
            const plan = plansData[selectedPlan];
            alert(`✅ ORDER CONFIRMED!\n\n📌 Brand: ${selectedBrand === 'brutal' ? '💀 BRUTAL SERVER' : '⚡ BGMI LOADER'}\n📌 Plan: ${plan.name}\n💰 Amount: ₹${plan.price}\n\n🔹 UPI ID: ksuraj138@ybl\n🔹 QR scan karo\n🔹 Payment screenshot WhatsApp/Telegram pe bhejo`);
        }

        // Modal Pages
        function showModal(type) {
            const modal = document.getElementById('modal');
            const title = document.getElementById('modalTitle');
            const body = document.getElementById('modalBody');
            
            if (type === 'privacy') {
                title.innerHTML = '<i class="fas fa-lock"></i> PRIVACY POLICY';
                body.innerHTML = `
                    <p>🔒 Aapki info safe hai. Kisi ke saath share nahi ki jati.</p>
                    <p>📱 UPI details sirf payment ke liye use hoti hain.</p>
                    <p>🚫 Third-party access strictly prohibited.</p>
                    <p>✅ 100% secure platform.</p>
                `;
            } else if (type === 'refund') {
                title.innerHTML = '<i class="fas fa-undo"></i> REFUND POLICY';
