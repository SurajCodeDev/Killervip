            <a href="#" onclick="showModal('terms')"><i class="fas fa-file"></i> Terms</a>
            <a href="#" onclick="showModal('support')"><i class="fas fa-headset"></i> Support</a>
        </div>

        <!-- PURCHASE CARD -->
        <div class="purchase-card">
            <div class="section-title">
                <i class="fas fa-bolt"></i> SELECT KEY <i class="fas fa-key"></i>
